rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /applicants/{uid} {
      allow create, read, update: if isOwner(uid);
    }

    match /applications/{applicationId} {
      allow create: if signedIn() && request.resource.data.applicantId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.applicantId == request.auth.uid;
    }

    match /uploads/{uid} {
      allow create, read, update: if isOwner(uid);
    }

    match /payments/{paymentId} {
      allow create: if signedIn() && request.resource.data.applicantId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.applicantId == request.auth.uid;
    }

    match /notifications/{notifId} {
      allow read, update, delete: if signedIn() && resource.data.recipientId == request.auth.uid;
      allow create: if signedIn();
    }

    match /ballot_results/{resultId} {
      allow read: if signedIn();
    }

    match /plots/{plotId} {
      allow read: if signedIn();
    }

    match /ballot_config/{docId} {
      allow read: if signedIn();
    }

    match /ballot_updates/{docId} {
      allow read: if signedIn();
    }

    match /payment_config/{docId} {
      allow read: if signedIn();
    }
  }
}
