rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /applicants/{userId} {
      allow read, create, update: if ownsUserDoc(userId);
      allow delete: if false;
    }

    match /applications/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /uploads/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /payments/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /notifications/{docId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /ballot_results/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /plots/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
